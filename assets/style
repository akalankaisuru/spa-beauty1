body{
    background:#f5f5f5;
}

.hero{
    background:linear-gradient(to right,#ff4da6,#ff99cc);
    color:white;
    padding:80px;
    text-align:center;
}

.product-card{
    background:white;
    border-radius:10px;
    padding:15px;
    box-shadow:0 0 10px rgba(0,0,0,0.1);
    margin-bottom:20px;
}

.product-card img{
    width:100%;
    height:220px;
    object-fit:cover;
}
